# Bu dosyayı .env olarak kopyala ve kendi değerlerini gir: cp .env.example .env
# .env dosyası .gitignore'da, yani commit'lenmez.

# docker-compose.yml'deki değerlerle aynı olmalı (lokal geliştirme için)
DB_URL=jdbc:postgresql://localhost:5432/ecommerce_db
DB_USERNAME=ecommerce_user
DB_PASSWORD=ecommerce_pass

# openssl rand -base64 64  ile üretebilirsin
JWT_SECRET=

JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Production'da true ve HTTPS zorunludur.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_DOMAIN=
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
CSRF_ENABLED=true

# Gmail için normal hesap şifresi değil, Google App Password kullan.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
